# ── Discord Bot ──────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Guild ID for development (commands register instantly to this guild)
# Remove or leave empty to register commands globally (takes up to 1 hour)
GUILD_ID=your_dev_guild_id_here

# ── AI Narrator (any OpenAI-compatible API) ──────────────
# API key for the AI provider
AI_API_KEY=your_api_key_here

# Base URL of the API endpoint. Examples:
#   OpenAI:      https://api.openai.com/v1
#   Ollama:      http://localhost:11434/v1
#   LM Studio:   http://localhost:1234/v1
#   Groq:        https://api.groq.com/openai/v1
#   Together AI: https://api.together.xyz/v1
#   Gemini:      https://generativelanguage.googleapis.com/v1beta/openai
AI_BASE_URL=https://api.cerebras.ai/v1

# Model name to use for narration
AI_MODEL=gpt-4o-mini

# ── Database ─────────────────────────────────────────────
# Path to the SQLite database file (relative to project root)
DB_PATH=./data/hungerfall.db

# ── Logging ──────────────────────────────────────────────
# Log level: error, warn, info, debug
LOG_LEVEL=info
